{
    "name": "epmnzava/airtel",
    "description": "php wrapper to integration with airtel",
    "keywords": [
        "epmnzava",
        "airtel"
    ],
    "homepage": "https://github.com/epmnzava/airtelapi",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Emmanuel Mnzava",
            "email": "epmnzava@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1|^8.2|^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Epmnzava\\Airtel\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Epmnzava\\Airtel\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-report": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}
